@blue
def decorator(f: dynamic) -> dynamic:
    @blue
    def inner() -> dynamic:
        print("Starting function")
        val = f()
        print("Ending function")
        return val
    return inner

@blue
def get_const():
    return "5"

@decorator
def foo() -> None:
    x = "hello"
    exec("""\
def bar() -> int:
    return """ + get_const())
    print(bar())

def main() -> None:
    foo()