@blue
def decorator(f: dynamic) -> dynamic:
    def inner() -> dynamic:
        print("Starting function")
        val = f()
        print("Ending function")
        return val
    return inner

@decorator
def foo() -> None:
    x = "hello"
    exec("""\
def bar() -> int:
    return 2
    """)
    print(bar())

def main() -> None:
    foo()